# Copy to .env and fill in your values. Never commit .env.

# --- Pushover (optional mobile alerts) ---
PUSHOVER_APP_TOKEN=your_pushover_app_token
PUSHOVER_USER_KEY=your_pushover_user_key

# --- Supabase (local: supabase start) ---
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Google AI / Gemini ---
GEMINI_API_KEY=your_gemini_api_key
GEMINI_PROJECT_NUMBER=your_gcp_project_number

# --- Google Cloud Storage ---
GCP_PROJECT_ID=your_gcp_project_id
GCP_BUCKET_NAME=your_grading_bucket

# --- Per-assignment paths (set by setup_and_run or manually) ---
SOLUTION_PDF_LOCAL_PATH=~/documents/grading/<assignment>/prompts/solutions.pdf
CURRENT_ASSIGNMENT=sample_assignment
ASSIGNMENT_CONTEXT_PATH=~/documents/grading/<assignment>/prompts/context.txt
ACTIVE_SYSTEM_PROMPT_PATH=~/documents/grading/<assignment>/assets/active_system_prompt.txt

# --- Optional tuning ---
REFINER_MODEL=gemini-2.5-flash
GRADEMASTER_DOCX_CONVERSION=libreoffice
GRADEMASTER_LIBREOFFICE_TIMEOUT_SEC=180
GRADEMASTER_ISSUE_HARD_WORD_CAP=28
